# answers.env — respostas para modo não-interativo
# Uso: ./setup.sh --answers answers.env
# Copie este arquivo, ajuste, e padronize o time inteiro com um comando.

# ── Escopo ────────────────────────────────────────────────────────────────────
# local  = .gemini/ no repo atual (recomendado)
# global = ~/.gemini/ (aplica a todos os repos)
SCOPE=local

# ── Perfil ────────────────────────────────────────────────────────────────────
# devops  = foco em infra, IaC, pipelines, K8s, GitOps
# appdev  = foco em aplicações (TypeScript, Python, .NET, Go, React, Next.js)
# tooling = foco em ferramentas DevOps (CLI, SDK, K8s client)
# custom  = escolher tudo manualmente
PROFILE=devops

# ── Stack (variam conforme o perfil) ──────────────────────────────────────────

# Clouds (separadas por vírgula): AWS, Azure, GCP
CLOUDS="AWS,Azure"

# Linguagens (separadas por vírgula): TypeScript, Python, C#/.NET, Go, Rust, Java
# (usado em perfis appdev, tooling, custom)
# LANGUAGES="TypeScript,Python"

# Framework backend (condicional à linguagem):
#   TypeScript: Express, Fastify, NestJS, Hono, Nenhum
#   Python: FastAPI, Django, Flask, Nenhum
#   C#/.NET: Minimal API, ASP.NET MVC, Nenhum
#   Go: Gin, Echo, Chi, stdlib, Nenhum
# BACKEND_FRAMEWORK=FastAPI

# Frontend: React, Next.js, Vue, Angular, Svelte, Nenhum
# FRONTEND=Nenhum

# CI/CD: "GitHub Actions" | "Azure Pipelines" | "GitLab CI" | Nenhum
CICD="Azure Pipelines"

# IaC: Terraform | CloudFormation | Pulumi | Nenhum
IAC=Terraform

# Kubernetes: Sim | Não
USE_K8S=Sim

# Bancos (separados por vírgula): PostgreSQL, MySQL, MongoDB, Redis, SQLite, Nenhum
DBS="PostgreSQL"

# Docker: Sim | Não
# USE_DOCKER=Sim

# VCS: GitHub | GitLab | Azure DevOps | Bitbucket | Nenhum
# VCS=GitHub

# ── Autenticação ──────────────────────────────────────────────────────────────
# api-key   = Google AI Studio API Key
# oauth     = Login via navegador (antigravity login)
# vertex-ai = Google Cloud Vertex AI (requer projeto GCP)
# skip      = Configurar depois
AUTH_METHOD=api-key

# Se api-key:
# GEMINI_API_KEY=AIza...  # ⚠️ NÃO commite este valor! Use variável de ambiente.

# Se vertex-ai:
# GCP_PROJECT=meu-projeto-gcp
# GCP_LOCATION=us-central1

# ── Modelo ────────────────────────────────────────────────────────────────────
# gemini-2.5-pro   = mais capaz, melhor pra planejamento e código complexo
# gemini-2.5-flash = mais rápido e barato, bom pra tarefas rotineiras
# custom           = ID de modelo customizado
MODEL=gemini-2.5-pro

# ── Agentes ───────────────────────────────────────────────────────────────────
# Depende do perfil:
#   devops:  architect, devops-engineer, reviewer
#   appdev:  architect, developer, reviewer, tester
#   tooling: architect, developer, reviewer, tester
#   custom:  architect, developer, devops-engineer, reviewer, tester
AGENTS="architect,devops-engineer,reviewer"
